<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane" prefHeight="800.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controlador.InscripcionNinoController">

    <!-- ===== BARRA SUPERIOR ===== -->
    <top>
        <HBox fx:id="topBar" alignment="CENTER_LEFT" prefHeight="60.0" spacing="15.0" style="-fx-background-color: #1A3A6B; -fx-padding: 0 20 0 20;">
            <Label fx:id="lblTitulo" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" text="ADSw-AGUGU - Sistema de Guardería" />
            <Pane HBox.hgrow="ALWAYS" />
            <Label fx:id="lblUsuario" style="-fx-text-fill: white; -fx-font-size: 13px;" text="Admin Sucursal - Juan Pérez" />
        </HBox>
    </top>

    <!-- ===== MENÚ LATERAL IZQUIERDO ===== -->
    <left>
        <VBox fx:id="sideMenu" prefWidth="210.0" spacing="4.0"
              style="-fx-background-color: #FFFFFF; -fx-border-color: #E0E0E0; -fx-border-width: 0 1 0 0;">
            <padding><Insets top="15" right="10" bottom="15" left="10"/></padding>

            <Button fx:id="btnInicio" text="Inicio" onAction="#abrirInicio"
                    maxWidth="1.7976931348623157E308" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-font-size: 14px; -fx-padding: 10 15 10 15;"/>

            <Button fx:id="btnNinos" text="Niños" onAction="#abrirInscripcion"
                    maxWidth="1.7976931348623157E308" alignment="CENTER_LEFT"
                    style="-fx-background-color: #E8EEF7; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 15 10 15; -fx-background-radius: 5;"/>

            <Button fx:id="btnEmpleados" text="Empleados" onAction="#abrirRegistroEmpleado"
                    maxWidth="1.7976931348623157E308" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-font-size: 14px; -fx-padding: 10 15 10 15;"/>

            <Button fx:id="btnPagos" text="Pagos" onAction="#abrirPagos"
                    maxWidth="1.7976931348623157E308" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-font-size: 14px; -fx-padding: 10 15 10 15;"/>

            <Button fx:id="btnActividades" text="Actividades" onAction="#abrirActividad"
                    maxWidth="1.7976931348623157E308" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-font-size: 14px; -fx-padding: 10 15 10 15;"/>

            <Button fx:id="btnVacunas" text="Vacunas" onAction="#abrirVacunacion"
                    maxWidth="1.7976931348623157E308" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-font-size: 14px; -fx-padding: 10 15 10 15;"/>

            <Button fx:id="btnReportes" text="Evaluaciones" onAction="#abrirEvaluacionEmpleado"
                    maxWidth="1.7976931348623157E308" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-font-size: 14px; -fx-padding: 10 15 10 15;"/>

            <Button fx:id="btnAyuda" text="Ayuda"
                    maxWidth="1.7976931348623157E308" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-font-size: 14px; -fx-padding: 10 15 10 15;"/>
        </VBox>
    </left>

    <!-- ===== CONTENIDO CENTRAL ===== -->
    <center>
        <ScrollPane fx:id="scrollCenter" fitToWidth="true">
            <VBox fx:id="contentVBox" spacing="15.0">
                <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

                <!-- Barra búsqueda + título sección -->
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <TextField fx:id="tfBusqueda" prefWidth="350.0" promptText="Consultar/Filtrar inscripciones existentes..." style="-fx-border-color: #CCCCCC; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8;" />
                    <Label fx:id="lblSeccion" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1A3A6B;" text="Inscripción de Niño" />
                </HBox>

                <!-- Panel principal dos columnas -->
                <HBox fx:id="mainPanel" spacing="15.0">

                    <!-- ====== COLUMNA IZQUIERDA — Datos del Niño ====== -->
                    <VBox fx:id="panelDatosNino" spacing="10.0" style="-fx-background-color: white; -fx-border-color: #CCCCCC; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 15;" HBox.hgrow="ALWAYS">

                        <Button fx:id="btnTituloDatos" maxWidth="1.7976931348623157E308" mouseTransparent="true" style="-fx-background-color: #1A3A6B; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 4;" text="Datos del Niño" />

                        <!-- Nombre Completo -->
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #555555;" text="Nombre Completo" />
                        <TextField fx:id="tfNombreCompleto" maxWidth="1.7976931348623157E308" promptText="Lucas Gómez" style="-fx-border-color: #CCCCCC; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 7;" />

                        <!-- Fecha + Tipo de inscripción -->
                        <HBox spacing="10.0">
                            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-size: 12px; -fx-text-fill: #555555;" text="Fecha de Nacimiento" />
                                <TextField fx:id="tfFechaNacimiento" maxWidth="1.7976931348623157E308" promptText="03/05/2020" style="-fx-border-color: #CCCCCC; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 7;" />
                            </VBox>
                            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-size: 12px; -fx-text-fill: #555555;" text="Tipo de Inscripción:" />
                                <ComboBox fx:id="cbTipoInscripcion" maxWidth="1.7976931348623157E308" promptText="4 meses" />
                            </VBox>
                        </HBox>

                        <!-- Número de Registro Civil -->
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #555555;" text="Número de Registro Civil" />
                        <TextField fx:id="tfRegistroCivil" maxWidth="1.7976931348623157E308" promptText="123415677" style="-fx-border-color: #CCCCCC; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 7;" />

                        <!-- Carné de Vacunas -->
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #555555;" text="Carné de Vacunas" />
                        <HBox>
                            <VBox fx:id="imgCarneVacunas" alignment="CENTER" prefHeight="90.0" prefWidth="90.0" style="-fx-border-color: #AAAAAA; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-background-color: #F5F5F5;">
                                <Label style="-fx-font-size: 28px;" text="📷" />
                            </VBox>
                        </HBox>

                        <!-- Marca de Pañal -->
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #555555;" text="Marca de Pañal" />
                        <TextField fx:id="tfMarcaPanialIzq" maxWidth="1.7976931348623157E308" promptText="Pañal" style="-fx-border-color: #CCCCCC; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 7;" />

                        <!-- Etapa -->
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #555555;" text="Etapa" />
                        <ComboBox fx:id="cbEtapaIzq" maxWidth="1.7976931348623157E308" promptText="Clasificación automática por edad (Acostaditos 0-6m)" />

                        <!-- Marca Leche Fórmula -->
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #555555;" text="Marca Leche Fórmula" />
                        <TextField fx:id="tfMarcaLecheIzq" maxWidth="1.7976931348623157E308" promptText="Fórmula" style="-fx-border-color: #CCCCCC; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 7;" />

                    </VBox>

                    <!-- ====== COLUMNA DERECHA — Detalles Adicionales ====== -->
                    <VBox fx:id="panelDetallesNino" spacing="10.0" style="-fx-background-color: white; -fx-border-color: #CCCCCC; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 15;" HBox.hgrow="ALWAYS">

                        <Button fx:id="btnTituloDetalles" maxWidth="1.7976931348623157E308" mouseTransparent="true" style="-fx-background-color: #E0E0E0; -fx-text-fill: #333333; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 4;" text="Detalles Adicionales del Niño" />

                        <!-- Marca de Pañal -->
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #555555;" text="Marca de Pañal" />
                        <TextField fx:id="tfMarcaPanialDer" maxWidth="1.7976931348623157E308" promptText="Pañal" style="-fx-border-color: #CCCCCC; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 7;" />

                        <!-- Etapa (solo lectura) -->
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #555555;" text="Etapa" />
                        <TextField fx:id="tfEtapaDer" editable="false" maxWidth="1.7976931348623157E308" promptText="Clasificación automática por edad (Acostaditos 0-6m)" style="-fx-border-color: #CCCCCC; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 7; -fx-background-color: #F5F5F5;" />

                        <!-- Marca Leche + Onzas -->
                        <HBox spacing="10.0">
                            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-size: 12px; -fx-text-fill: #555555;" text="Marca Leche Fórmula" />
                                <TextField fx:id="tfMarcaLecheDer" maxWidth="1.7976931348623157E308" promptText="Marca Leche" style="-fx-border-color: #CCCCCC; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 7;" />
                            </VBox>
                            <VBox spacing="4.0">
                                <Label style="-fx-font-size: 12px; -fx-text-fill: #555555;" text="Onzas" />
                                <TextField fx:id="tfOnzas" prefWidth="80.0" promptText="4" style="-fx-border-color: #CCCCCC; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 7;" />
                            </VBox>
                        </HBox>

                        <!-- Dieta Inicial -->
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #555555;" text="Dieta Inicial" />
                        <TextArea fx:id="taDietaInicial" maxWidth="1.7976931348623157E308" prefHeight="220.0" style="-fx-border-color: #CCCCCC; -fx-border-radius: 4; -fx-background-radius: 4;" text="Alimentos Permitidos&#10;- Leche materna o fórmula&#10;- Purés de frutas&#10;- Purés de verduras&#10;- Cereales infantiles&#10;&#10;Alimentos Prohibidos&#10;- Leche entera (menor de 1 año)&#10;- Miel (menor de 1 año)&#10;- Sal y azúcar añadidos&#10;- Frutos secos enteros (riesgo de asfixia)" wrapText="true" />

                    </VBox>

                </HBox>
            </VBox>
        </ScrollPane>
    </center>

    <!-- ===== BOTONES INFERIORES ===== -->
    <bottom>
        <HBox fx:id="bottomBar" alignment="CENTER" spacing="15.0" style="-fx-background-color: #F5F5F5; -fx-border-color: #CCCCCC; -fx-border-width: 1 0 0 0;">
            <padding><Insets bottom="15" left="20" right="20" top="15" /></padding>

            <Button fx:id="btnGuardar" onAction="#guardarNino" style="-fx-background-color: #1A3A6B; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 12 20 12 20; -fx-background-radius: 5; -fx-cursor: hand;" text="Guardar y Asignar Sucursal Más Cercana" />
            <Button fx:id="btnCancelar" onAction="#cancelar" style="-fx-background-color: #1A3A6B; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 12 20 12 20; -fx-background-radius: 5; -fx-cursor: hand;" text="Cancelar" />
            <Button fx:id="btnListaEspera" onAction="#agregarListaEspera" style="-fx-background-color: #1A3A6B; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 12 20 12 20; -fx-background-radius: 5; -fx-cursor: hand;" text="Agregar a Lista de Espera" />
        </HBox>
    </bottom>

</BorderPane>
